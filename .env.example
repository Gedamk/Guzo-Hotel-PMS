# Guzo Guest Assist - sample environment configuration
# Copy this file to .env locally and fill in real values outside version control.

# App
ENVIRONMENT=development
CITY=Addis Ababa

# Backend database
GUZO_DB_HOST=localhost
GUZO_DB_PORT=5432
GUZO_DB_NAME=guzo
GUZO_DB_USER=guzo_user
GUZO_DB_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://guzo_user:change-me@localhost:5432/guzo

# Auth
GUZO_DEFAULT_ADMIN_PASSWORD=change-this-password
GUZO_JWT_SECRET=change-this-secret

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Weather
OPENWEATHER_API_KEY=your-openweather-api-key

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
MANAGER_CHAT_ID=your-manager-chat-id

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON=creds/service_account.json
GOOGLE_APPLICATION_CREDENTIALS=creds/service_account.json
HOTEL_CONTACT_SHEET_ID=your-hotel-contact-sheet-id
BOOKING_LOG_SHEET_ID=your-booking-log-sheet-id
BOOKING_LOG_SHEET_NAME=Sheet1
SOFI_HOTEL_SHEET_ID=your-sofi-hotel-sheet-id
SPREADSHEET_GUZO_NOTIFICATIONS_LOG_ID=your-notifications-log-sheet-id
SPREADSHEET_GUZO_SYSTEM_MASTER_ID=your-system-master-sheet-id
SYSTEM_MASTER_SHEET_ID=your-system-master-tab-id

# Email / SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_SENDER_EMAIL=no-reply@example.com
REPLY_TO_EMAIL=support@example.com
SENDER_EMAIL=reports@example.com
FROM_EMAIL=reports@example.com
SYSTEM_EMAIL=center@example.com
EMAIL_SUBJECT_PREFIX=[Guzo Reports]
TEST_EMAIL=test@example.com
TO_EMAIL=owner@example.com
ALERT_EMAIL=alerts@example.com
BOOKING_ALERT_EMAIL=bookings@example.com
HOTEL_NOTIFICATIONS_EMAIL=gm@example.com

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000

# Payments
CHAPA_PUBLIC_KEY=your-chapa-public-key
CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret
STRIPE_API_KEY=your-stripe-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_DEV_AUTH_FALLBACK=true
VITE_PROPERTY_CODE=DRE001
VITE_PROPERTY_NAME=Dream Big Hotel
