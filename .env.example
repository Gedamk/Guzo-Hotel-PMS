# Copy this file to .env and fill in real values (never commit the real .env)
ENV=development

# Email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_SENDER_EMAIL=noreply@example.com
SENDGRID_SENDER_NAME="Guzo Guest Assist"
GMAIL_EMAIL=
GMAIL_PASSWORD=

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Sheets
SERVICE_ACCOUNT_FILE=guzo_booking_bot/creds/guzo_service_account.json
GOOGLE_CREDS_FILE=guzo_booking_bot/creds/guzo_service_account.json
SPREADSHEET_GUEST_ASSIST_ID=
SPREADSHEET_HOTEL_CONTACTS_ID=
SPREADSHEET_NOTIFICATIONSLOG_ID=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TELEBIRR_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# Seasonality overrides
FORCE_SEASON_INTL=
FORCE_SEASON_ETH=
FORCE_DISCOUNT=
FORCE_VALID_UNTIL=
